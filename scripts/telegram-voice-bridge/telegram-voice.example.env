# Copy to a path outside the repo (e.g. ~/.config/openclaw/telegram-voice.env) and chmod 600.
# shellcheck disable=SC2034

# Telegram Bot API (same pattern as scripts/observer/telegram.env.example)
TELEGRAM_BOT_TOKEN=
# Optional default chat for CLI when --chat-id is omitted
TELEGRAM_CHAT_ID=

# Public HTTPS base where voice-session-shell.html is hosted (no trailing slash).
# Example: https://claw.example.com/static/voice
VOICE_SESSION_PUBLIC_BASE=

# Optional: Twilio Programmable Voice (outbound calls to real phone numbers).
# Telegram cannot place these calls; we notify the user in Telegram, then call via Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 caller ID you own on Twilio
TWILIO_FROM_NUMBER=
